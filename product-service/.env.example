# Product Service — copy to .env for local development
#   cp .env.example .env

APP_NAME=Product Service
ENVIRONMENT=development

# PostgreSQL (async driver)
# Homebrew/local: your macOS username, no password (replace YOUR_MAC_USERNAME)
DATABASE_URL=postgresql+asyncpg://YOUR_MAC_USERNAME@localhost:5432/product_db

# Redis (shared server; product uses logical DB 1)
REDIS_URL=redis://localhost:6379/1

# JWT — must match auth-service JWT_SECRET_KEY
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256

PRODUCT_CACHE_TTL_SECONDS=300
