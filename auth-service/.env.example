# Auth Service — copy to .env for local development
#   cp .env.example .env

APP_NAME=Auth Service
ENVIRONMENT=development

# PostgreSQL (async driver)
# Homebrew/local: your macOS username, no password (replace YOUR_MAC_USERNAME)
DATABASE_URL=postgresql+asyncpg://YOUR_MAC_USERNAME@localhost:5432/auth_db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT — must match product-service JWT_SECRET_KEY
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# bcrypt cost factor (minimum 12 per spec)
BCRYPT_ROUNDS=12

# Login rate limiting
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
